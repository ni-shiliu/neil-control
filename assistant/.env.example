EMAIL_USER=your-account@163.com
# 163 授权码（非登录密码）：163网页版 → 设置 → POP3/SMTP/IMAP → 开启IMAP → 生成授权码
EMAIL_PASS=your-163-auth-code

# 二选一：官方 API 或公司代理
# 官方 API：只需配置 ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=your-anthropic-api-key
# 公司代理：配置 BASE_URL + AUTH_TOKEN
ANTHROPIC_BASE_URL=https://xxx
ANTHROPIC_AUTH_TOKEN=your-auth-token
ANTHROPIC_MODEL=claude-sonnet-4-6

# 邮件自动发送开关
# true  = risk=low 且 confidence >= AUTO_SEND_CONFIDENCE 时直接发送
# false = 所有回复统一存草稿，人工确认后再发（默认）
EMAIL_AUTO_SEND=false
# 自动发送的最低置信度（0-100），低于此值强制存草稿
EMAIL_AUTO_SEND_CONFIDENCE=75

# Telegram Bot
# Token：找 @BotFather 发 /newbot 获取
TELEGRAM_BOT_TOKEN=your-bot-token
# Chat ID：找 @userinfobot 发任意消息获取
TELEGRAM_CHAT_ID=your-chat-id

# 和风天气（免费注册：dev.qweather.com）
QWEATHER_API_KEY=your-qweather-key
# 免费版 API Host（项目管理页面里的 API Host 字段，形如 xxx.re.qweatherapi.com）
QWEATHER_API_HOST=your-api-host.re.qweatherapi.com
# 城市 ID 查询：https://github.com/qwd/LocationList
# 常用：北京 101010100 / 上海 101020100 / 广州 101280101 / 深圳 101280601
WEATHER_CITY_ID=101020100
